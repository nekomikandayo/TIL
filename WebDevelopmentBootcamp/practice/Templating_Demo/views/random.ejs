<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>ランダムな値：<%= rand %> </h1>
    <% if (rand % 2 === 0) { %>
        <h2>偶数</h2>
    <% } else { %>
        <h2>奇数</h2>
    <% } %>

    <h3><%= num % 2 === 0 ? '偶数' : '奇数' %></h3>
</body>
</html>